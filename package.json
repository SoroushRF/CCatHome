{
  "name": "ccathome",
  "version": "1.0.0",
  "description": "Portable multi-step agent execution layer using the Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "npm run build && node dist/index.js",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" && node scripts/lint-gate-bypass.js && node scripts/lint-no-magic-status.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "benchmark:v1": "node scripts/run-benchmark-task.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "better-sqlite3": "^12.11.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "tsup": "^8.1.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
